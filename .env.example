# ═══════════════════════════════════════════════════════════════════
#  NEXIA OS v41 — Variáveis de Ambiente
#  Copie este ficheiro para .env e preencha os valores reais.
#  NUNCA commite o ficheiro .env para o repositório.
#  Todas as variáveis marcadas com [OBRIGATÓRIO] são necessárias
#  para o sistema funcionar. As restantes são opcionais.
# ═══════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────
# FIREBASE — Backend principal (Firestore + Auth + Admin SDK)
# [OBRIGATÓRIO] Escolha UMA das duas opções abaixo:
# ───────────────────────────────────────────────────────────────────

# Opção A — JSON raw (cole o conteúdo do serviceAccountKey.json)
FIREBASE_SERVICE_ACCOUNT='{...json completo da service account...}'

# Opção B — Base64 (recomendado para Netlify: base64 do JSON acima)
# Para gerar: cat serviceAccountKey.json | base64
FIREBASE_SERVICE_ACCOUNT_BASE64=

# URL pública da aplicação (sem barra no final)
# [OBRIGATÓRIO]
NEXIA_APP_URL=https://seudominio.onrender.com

# Domínio de email dos tenants (usado em convites e dunning)
# [OBRIGATÓRIO]
NEXIA_EMAIL_DOMAIN=seudominio.com

# Ambiente (development | production)
NODE_ENV=production

# URL interna Netlify (preenchida automaticamente em produção)
# URL pública do Render (mesma que NEXIA_APP_URL acima)
URL=https://seudominio.onrender.com


# ───────────────────────────────────────────────────────────────────
# IA — Modelos de Linguagem
# Pelo menos GROQ_API_KEY ou ANTHROPIC_API_KEY é necessário.
# ───────────────────────────────────────────────────────────────────

# Groq — modelos rápidos (Llama, Mixtral) — [OBRIGATÓRIO para CORTEX]
GROQ_API_KEY=gsk_...

# Anthropic — Claude Sonnet/Opus — [OBRIGATÓRIO para agentes avançados]
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — GPT-4o, GPT-4 Turbo
OPENAI_API_KEY=sk-...

# Google — Gemini Pro / Gemini Flash
GEMINI_API_KEY=

# DeepSeek — modelos reasoning (R1, V3)
DEEPSEEK_API_KEY=

# Mistral AI — Mistral Large, Mixtral
MISTRAL_API_KEY=

# xAI — Grok
XAI_API_KEY=

# Perplexity — pesquisa com fontes
PERPLEXITY_API_KEY=

# OpenRouter — gateway multi-modelo
OPENROUTER_API_KEY=

# Together AI — modelos open-source
TOGETHER_API_KEY=

# Cohere — embeddings e Command
COHERE_API_KEY=

# Cerebras — inferência ultra-rápida
CEREBRAS_API_KEY=

# SambaNova — modelos enterprise
SAMBANOVA_API_KEY=

# Hugging Face — modelos open-source
HF_API_KEY=

# NVIDIA NIM — modelos acelerados
NVIDIA_API_KEY=


# ───────────────────────────────────────────────────────────────────
# PAGAMENTOS
# ───────────────────────────────────────────────────────────────────

# Mercado Pago — [OBRIGATÓRIO para cobrança]
MP_ACCESS_TOKEN=APP_USR-...
MP_WEBHOOK_SECRET=

# Stripe — (opcional, alternativo ao Mercado Pago)
STRIPE_SECRET_KEY=sk_live_...


# ───────────────────────────────────────────────────────────────────
# WHATSAPP BUSINESS API (Meta)
# [OBRIGATÓRIO após fix VULN-06 — HMAC agora obrigatório]
# ───────────────────────────────────────────────────────────────────

# Segredo da App Meta — para validação HMAC dos webhooks
META_APP_SECRET=

# Token de acesso à API WhatsApp Business
META_WHATSAPP_TOKEN=

# Token de verificação do webhook (qualquer string segura)
META_WEBHOOK_VERIFY_TOKEN=

# ID do WhatsApp Business Account
META_WABA_ID=

# Token legacy (fallback para integrações antigas)
WHATSAPP_TOKEN=

# ID do número de telefone do WhatsApp
WHATSAPP_PHONE_ID=


# ───────────────────────────────────────────────────────────────────
# DUNNING (cobrança automática)
# [OBRIGATÓRIO após fix VULN-05 — sem fallback hardcoded]
# Gerar com: openssl rand -hex 32
# ───────────────────────────────────────────────────────────────────

DUNNING_SECRET=


# ───────────────────────────────────────────────────────────────────
# EMAIL (notificações dunning + convites)
# ───────────────────────────────────────────────────────────────────

# Resend — serviço de email transacional
RESEND_API_KEY=re_...


# ───────────────────────────────────────────────────────────────────
# RENDER (deploy programático via Arquiteto IA)
# NOTA: projeto migrado de Netlify → Render. NETLIFY_API_TOKEN e
# NETLIFY_SITE_ID foram removidos — use RENDER_DEPLOY_HOOK abaixo.
# ───────────────────────────────────────────────────────────────────

# Deploy Hook do Render (Dashboard → Settings → Deploy Hooks)
RENDER_DEPLOY_HOOK=https://api.render.com/deploy/...

# API Key do Render (opcional — para Arquiteto listar services)
RENDER_API_KEY=


# ───────────────────────────────────────────────────────────────────
# NF-e (Nota Fiscal Electrónica)
# ───────────────────────────────────────────────────────────────────

NFEIO_API_KEY=


# ───────────────────────────────────────────────────────────────────
# IoT / FECHADURAS (Sentinel IoT — Viajante Pro)
# ───────────────────────────────────────────────────────────────────

TTLOCK_CLIENT_ID=
TTLOCK_ACCESS_TOKEN=

# ───────────────────────────────────────────────────────────────────
# MÉTRICAS GLOBAIS (acesso master — protegido por bearer token)
# [OBRIGATÓRIO para /api/metrics funcionar]
# Gerar com: openssl rand -hex 32
# ───────────────────────────────────────────────────────────────────
METRICS_SECRET=


# ───────────────────────────────────────────────────────────────────
# FIREBASE CLIENT CONFIG (Frontend — exposta ao browser via window)
# Estas variáveis são PÚBLICAS por design do Firebase SDK, mas devem
# ser configuradas via variáveis de ambiente e não via hardcode.
# No Netlify: Site Settings → Environment variables
# ───────────────────────────────────────────────────────────────────
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:abc123
