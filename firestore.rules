rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function isOwner(userId) { return isAuth() && uid() == userId; }

    // Usuários leem/escrevem o próprio documento
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{sub}/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Tenants — qualquer autenticado lê, qualquer autenticado escreve
    // (controle real de escrita é feito pelo server-side Admin SDK)
    match /tenants/{tenantSlug} {
      allow read, write: if isAuth();
      match /{col}/{docId} {
        allow read, write: if isAuth();
      }
      match /{col}/{docId}/{sub}/{subDocId} {
        allow read, write: if isAuth();
      }
    }

    // Rate limits — server-side only (Admin SDK bypasses rules)
    match /rate_limits/{docId} {
      allow read, write: if false;
    }

    // Config pública — qualquer autenticado lê
    match /nexia_config/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Logs do Cortex — usuário lê os próprios
    match /cortex_logs/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Sentinel e observability — leitura autenticada
    match /sentinel_reports/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }
    match /system_status/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }
    match /alerts/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Tudo mais — bloqueado no client, liberado pelo Admin SDK
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
